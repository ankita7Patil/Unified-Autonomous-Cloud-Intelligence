# GCP
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
BIGQUERY_DATASET=uaci_data
FIRESTORE_DATABASE=(default)

# Gemini (Google AI Studio — free tier)
GEMINI_API_KEY=your_ai_studio_api_key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
GEMINI_RPM_LIMIT=14              # stay under 15 RPM free limit
GEMINI_MAX_TOKENS=2048

# Pub/Sub Topics
PUBSUB_RAW_SECURITY=raw-security-events
PUBSUB_RAW_BILLING=raw-billing-events
PUBSUB_INCIDENTS=incident-alerts
PUBSUB_ACTIONS=action-commands

# Cloud Storage
GCS_BUCKET=uaci-mvp-artifacts
GCS_IAC_PREFIX=iac-patches/
GCS_RUNBOOKS_PREFIX=runbooks/

# App Config
DEMO_MODE=true                   # uses seeded demo data for fast demos
LOG_LEVEL=INFO
ENVIRONMENT=production
